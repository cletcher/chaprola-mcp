  "mcpName": "io.github.cletcher/chaprola",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
